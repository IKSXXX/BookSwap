@model ExchangeDetailsViewModel
@{
    ViewData["Title"] = $"Обмен #{Model.Id}";
    var statusBadge = Model.Status switch
    {
        ExchangeStatus.Pending => "badge--yellow",
        ExchangeStatus.Accepted => "badge--blue",
        ExchangeStatus.Completed => "badge--green",
        ExchangeStatus.Rejected => "badge--red",
        ExchangeStatus.Cancelled => "badge--secondary",
        _ => "badge--secondary",
    };
    var other = Model.CurrentUserId == Model.Sender.Id ? Model.Receiver : Model.Sender;
    string CondClass(string label) => label switch
    {
        "Отличное" or "Новое" => "badge--green",
        "Хорошее" => "badge--blue",
        "Удовлетворительное" => "badge--yellow",
        _ => "badge--secondary"
    };
}

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <a href="javascript:history.back()" class="btn btn-ghost btn-sm mb-6">
            <svg class="icon"><use href="#i-arrow-left"/></svg>
            Назад
        </a>

        @* Header card *@
        <div class="card mb-6">
            <div class="card-body">
                <div class="exchange-head">
                    <div class="exchange-head__user">
                        @if (!string.IsNullOrEmpty(other.Avatar))
                        {
                            <img src="@other.Avatar" alt="@other.Name" class="owner-avatar" />
                        }
                        else
                        {
                            <img src="/images/avatars/profile_icon.png" alt="@other.Name" class="owner-avatar" />
                        }
                        <div>
                            <h3 class="mb-1">Обмен с <a asp-controller="User" asp-action="Details" asp-route-id="@other.Id" class="exchange-row__name-link">@other.Name</a></h3>
                            <div class="text-sm text-muted flex items-center gap-2">
                                <svg class="icon rating-star icon--fill"><use href="#i-star"/></svg>
                                <span>@other.Rating.ToString("0.0")</span>
                                <span>·</span>
                                <span>Создан @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <span class="badge @statusBadge">@Model.StatusLabel</span>
                </div>
            </div>
        </div>

        <div class="exchange-detail-grid">
            @* Chat *@
            <div class="chat-card">
                <div class="chat-card__head">
                    <h3>
                        <svg class="icon text-primary"><use href="#i-message-circle"/></svg>
                        Чат обмена
                    </h3>
                </div>
                <div id="chatMessages" class="chat-messages"
                     data-exchange-id="@Model.Id"
                     data-current-user="@Model.CurrentUserId">
                    @if (Model.Messages.Count == 0)
                    {
                        <div class="chat-empty">
                            <svg class="icon"><use href="#i-chat"/></svg>
                            <p>Пока нет сообщений. Напишите первым!</p>
                        </div>
                    }
                    else
                    {
                        DateTime? lastDay = null;
                        foreach (var message in Model.Messages)
                        {
                            var localDay = message.SentAt.ToLocalTime().Date;
                            if (lastDay != localDay)
                            {
                                lastDay = localDay;
                                var label = localDay == DateTime.Today ? "Сегодня"
                                    : localDay == DateTime.Today.AddDays(-1) ? "Вчера"
                                    : localDay.ToString("dd MMMM yyyy");
                                <div class="chat-date-sep">@label</div>
                            }
                            var mine = message.SenderId == Model.CurrentUserId;
                            <div class="chat-row @(mine ? "chat-row--mine" : "")">
                                <div class="chat-bubble @(mine ? "chat-bubble--mine" : "chat-bubble--theirs")">
                                    <div class="chat-text">@message.Text</div>
                                    <time>@message.SentAt.ToLocalTime().ToString("HH:mm")</time>
                                </div>
                            </div>
                        }
                    }
                </div>
                @if (Model.Status == ExchangeStatus.Pending || Model.Status == ExchangeStatus.Accepted)
                {
                    <form id="chatForm" class="chat-compose">
                        <input type="text" id="chatInput" placeholder="Напишите сообщение..." maxlength="1000" autocomplete="off" />
                        <button type="submit" class="btn btn-primary">
                            <svg class="icon"><use href="#i-send"/></svg>
                        </button>
                    </form>
                }
            </div>

            @* Sidebar *@
            <aside class="stack-lg">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <svg class="icon text-primary"><use href="#i-swap"/></svg>
                            Детали обмена
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="text-muted text-sm mb-2">Вы получаете</div>
                        @if (Model.BookRequested != null)
                        {
                            <div class="book-pick book-pick--them book-pick--selected mb-4">
                                <div class="book-pick__cover">
                                    @if (!string.IsNullOrEmpty(Model.BookRequested.CoverImagePath))
                                    {
                                        <img src="@Model.BookRequested.CoverImagePath" alt="@Model.BookRequested.Title" />
                                    }
                                    else
                                    {
                                        <div class="book-card__placeholder"><svg class="icon"><use href="#i-book"/></svg></div>
                                    }
                                </div>
                                <div class="book-pick__body">
                                    <div class="book-pick__title">@Model.BookRequested.Title</div>
                                    <div class="book-pick__author">@Model.BookRequested.Author</div>
                                    <span class="badge @CondClass(Model.BookRequested.ConditionLabel)">@Model.BookRequested.ConditionLabel</span>
                                </div>
                            </div>
                        }

                        <div class="text-muted text-sm mb-2">Вы отдаёте</div>
                        @if (Model.BookOffered != null)
                        {
                            <div class="book-pick book-pick--my book-pick--selected">
                                <div class="book-pick__cover">
                                    @if (!string.IsNullOrEmpty(Model.BookOffered.CoverImagePath))
                                    {
                                        <img src="@Model.BookOffered.CoverImagePath" alt="@Model.BookOffered.Title" />
                                    }
                                    else
                                    {
                                        <div class="book-card__placeholder"><svg class="icon"><use href="#i-book"/></svg></div>
                                    }
                                </div>
                                <div class="book-pick__body">
                                    <div class="book-pick__title">@Model.BookOffered.Title</div>
                                    <div class="book-pick__author">@Model.BookOffered.Author</div>
                                    <span class="badge @CondClass(Model.BookOffered.ConditionLabel)">@Model.BookOffered.ConditionLabel</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="book-pick book-pick--my">
                                <div class="book-pick__cover book-pick__cover--icon">
                                    <svg class="icon"><use href="#i-heart"/></svg>
                                </div>
                                <div class="book-pick__body">
                                    <div class="book-pick__title">Безвозмездно</div>
                                    <div class="book-pick__author">Передача в дар</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (Model.CanAccept || Model.CanReject || Model.CanCancel || Model.CanComplete || Model.CanLeaveReview)
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">
                                <svg class="icon text-primary"><use href="#i-settings"/></svg>
                                Действия
                            </h3>
                        </div>
                        <div class="card-body stack">
                            @if (Model.CanAccept)
                            {
                                <form asp-action="Accept" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button class="btn btn-accept btn-block">
                                        <svg class="icon"><use href="#i-check"/></svg>
                                        Принять обмен
                                    </button>
                                </form>
                            }
                            @if (Model.CanReject)
                            {
                                <form asp-action="Reject" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button class="btn btn-reject btn-block">
                                        <svg class="icon"><use href="#i-x"/></svg>
                                        Отклонить
                                    </button>
                                </form>
                            }
                            @if (Model.CanCancel)
                            {
                                <form asp-action="Cancel" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button class="btn btn-cancel-action btn-block">
                                        <svg class="icon"><use href="#i-x"/></svg>
                                        Отменить заявку
                                    </button>
                                </form>
                            }
                            @if (Model.CanComplete)
                            {
                                <form asp-action="Complete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button class="btn btn-accept btn-block">
                                        <svg class="icon"><use href="#i-check"/></svg>
                                        Завершить обмен
                                    </button>
                                </form>
                            }
                            @if (Model.CanLeaveReview)
                            {
                                <a asp-action="LeaveReview" asp-route-id="@Model.Id" class="btn btn-add btn-block">
                                    <svg class="icon"><use href="#i-star"/></svg>
                                    Оставить отзыв
                                </a>
                            }
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (async () => {
            const box = document.getElementById('chatMessages');
            const exchangeId = parseInt(box.dataset.exchangeId);
            const currentUserId = box.dataset.currentUser;
            box.scrollTop = box.scrollHeight;

            const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/chat').withAutomaticReconnect().build();

            conn.on('ReceiveMessage', m => {
                const empty = box.querySelector('.chat-empty');
                if (empty) empty.remove();
                const mine = m.senderId === currentUserId;
                const row = document.createElement('div');
                row.className = 'chat-row' + (mine ? ' chat-row--mine' : '');
                const d = new Date(m.sentAt);
                const time = d.toTimeString().slice(0,5);
                row.innerHTML = `<div class="chat-bubble ${mine ? 'chat-bubble--mine' : 'chat-bubble--theirs'}"><div class="chat-text"></div><time>${time}</time></div>`;
                row.querySelector('.chat-text').textContent = m.text;
                box.appendChild(row);
                box.scrollTop = box.scrollHeight;
            });

            try {
                await conn.start();
                await conn.invoke('JoinGroup', exchangeId);
            } catch (e) { console.error('Chat connect failed', e); }

            const form = document.getElementById('chatForm');
            form?.addEventListener('submit', async e => {
                e.preventDefault();
                const input = document.getElementById('chatInput');
                const text = input.value.trim();
                if (!text) return;
                try {
                    await conn.invoke('SendMessage', exchangeId, text);
                    input.value = '';
                } catch (err) { console.error(err); }
            });
        })();
    </script>
}
