@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1>Регистрация</h1>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="UserName">Имя пользователя</label>
                <input asp-for="UserName" class="form-input" />
            </div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" class="form-input" />
            </div>
            <div class="form-group">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" type="password" class="form-input" />
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword">Подтвердите пароль</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input" />
            </div>
            <button type="submit" class="btn btn-primary w-full">Зарегистрироваться</button>
        </form>
        <p class="auth-footer">Уже есть аккаунт? <a asp-action="Login">Войти</a></p>
    </div>
</div>
