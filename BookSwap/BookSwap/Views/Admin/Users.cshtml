@model List<AdminUserListItemViewModel>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <a asp-action="Index" class="btn btn-ghost mb-4">
            <svg class="icon" style="width:1.125rem;height:1.125rem"><use href="#i-arrow-left"/></svg>
            Назад
        </a>
        <h1 class="mb-6">Пользователи</h1>

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Email</th>
                        <th>Рейтинг</th>
                        <th>Книг</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="@(user.IsBlocked ? "row-hidden" : "")">
                            <td><a asp-controller="User" asp-action="Details" asp-route-id="@user.Id" style="font-weight:600;color:var(--gray-900);">@user.UserName</a></td>
                            <td class="text-muted">@user.Email</td>
                            <td>@user.Rating.ToString("0.0")</td>
                            <td>@user.BooksCount</td>
                            <td class="text-muted">@user.RegistrationDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge badge--red">Заблокирован</span>
                                }
                                @if (user.IsAdmin)
                                {
                                    <span class="badge badge--blue">Admin</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex;gap:.5rem;">
                                    <form asp-action="ToggleBlock" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button class="btn btn-ghost btn-sm">@(user.IsBlocked ? "Разблокировать" : "Заблокировать")</button>
                                    </form>
                                    <form asp-action="ToggleAdmin" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button class="btn btn-ghost btn-sm">@(user.IsAdmin ? "Убрать админа" : "Сделать админом")</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
