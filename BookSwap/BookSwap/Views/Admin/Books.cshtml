@model List<Book>
@{
    ViewData["Title"] = "Книги";
}

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <a asp-action="Index" class="btn btn-ghost mb-4">
            <svg class="icon" style="width:1.125rem;height:1.125rem"><use href="#i-arrow-left"/></svg>
            Назад
        </a>
        <h1 class="mb-6">Книги</h1>

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Автор</th>
                        <th>Жанр</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr class="@(book.IsHidden ? "row-hidden" : "")">
                            <td><a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" style="font-weight:600;color:var(--gray-900);">@book.Title</a></td>
                            <td class="text-muted">@book.Author</td>
                            <td><span class="badge badge--secondary">@book.Genre</span></td>
                            <td>
                                @if (book.IsHidden)
                                {
                                    <span class="badge badge--red">Скрыта</span>
                                }
                                else if (!book.IsAvailable)
                                {
                                    <span class="badge badge--yellow">Недоступна</span>
                                }
                                else
                                {
                                    <span class="badge badge--green">Доступна</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex;gap:.5rem;">
                                    <form asp-action="ToggleHidden" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@book.Id" />
                                        <button class="btn btn-ghost btn-sm">@(book.IsHidden ? "Показать" : "Скрыть")</button>
                                    </form>
                                    <form asp-action="DeleteBook" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@book.Id" />
                                        <button class="btn btn-ghost btn-sm" style="color:var(--red-600);">Удалить</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
