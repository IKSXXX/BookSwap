@model QuizQuestionFormViewModel
@{
    var isEdit = Model.Id.HasValue && Model.Id > 0;
    ViewData["Title"] = isEdit ? "Редактировать вопрос" : "Новый вопрос";
}

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container" style="max-width:600px;">
        <a asp-action="Quiz" class="btn btn-ghost btn-sm mb-4">
            <svg class="icon" style="width:1.125rem;height:1.125rem"><use href="#i-arrow-left"/></svg>
            К списку
        </a>
        <h1 class="mb-4">@(isEdit ? "Редактировать вопрос" : "Новый вопрос")</h1>

        <form asp-action="@(isEdit ? "EditQuiz" : "CreateQuiz")" method="post">
            @Html.AntiForgeryToken()
            @if (isEdit) { <input type="hidden" asp-for="Id" /> }
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="card mb-4">
                <div class="card-body">
                    <div class="form-group">
                        <label asp-for="BookId">Книга</label>
                        <select asp-for="BookId" class="form-input">
                            @foreach (var book in Model.AvailableBooks) { <option value="@book.Id">@book.Title — @book.Author</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="Quote">Цитата</label>
                        <textarea asp-for="Quote" rows="3" class="form-input" placeholder="Отрывок из книги..."></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="CorrectAnswer">Правильный ответ</label>
                        <input asp-for="CorrectAnswer" class="form-input" />
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
                        <div class="form-group">
                            <label asp-for="Option2">Вариант 2</label>
                            <input asp-for="Option2" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label asp-for="Option3">Вариант 3</label>
                            <input asp-for="Option3" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label asp-for="Option4">Вариант 4</label>
                            <input asp-for="Option4" class="form-input" />
                        </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">@(isEdit ? "Сохранить изменения" : "Сохранить")</button>
        </form>
    </div>
</div>
