@model BookFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Редактировать книгу" : "Добавить книгу";
}

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <a asp-controller="Book" asp-action="Index" class="btn btn-ghost btn-sm mb-6">
            <svg class="icon"><use href="#i-arrow-left"/></svg>
            К каталогу
        </a>

        <div class="form-wrap">
            <div class="mb-6">
                <h1 class="mb-2">@ViewData["Title"]</h1>
                <p class="text-muted">Заполните информацию о книге — это займёт пару минут.</p>
            </div>

            <form asp-action="@(isEdit ? "Edit" : "Create")" asp-controller="Book" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                @if (isEdit) { <input type="hidden" asp-for="Id" /> }
                <div asp-validation-summary="All" class="text-danger text-sm mb-2"></div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Основное</h3>
                    </div>
                    <div class="card-body stack">
                        <div class="form-group">
                            <label asp-for="Title" class="form-label">Название</label>
                            <input asp-for="Title" class="form-input" />
                            <span asp-validation-for="Title" class="text-danger text-sm"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Author" class="form-label">Автор</label>
                            <input asp-for="Author" class="form-input" />
                            <span asp-validation-for="Author" class="text-danger text-sm"></span>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="ISBN" class="form-label">ISBN <span class="text-muted text-xs">(опционально)</span></label>
                                <input asp-for="ISBN" id="isbnInput" class="form-input" />
                            </div>
                            <div class="form-group" style="align-self:flex-end;">
                                <button type="button" id="fetchIsbnBtn" class="btn btn-outline w-full">
                                    <svg class="icon"><use href="#i-sparkles"/></svg>
                                    Автозаполнить
                                </button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" rows="5" class="form-input form-textarea"></textarea>
                        </div>
                    </div>
                </div>

                <div class="card mt-4">
                    <div class="card-header">
                        <h3 class="card-title">Детали</h3>
                    </div>
                    <div class="card-body stack">
                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Genre" class="form-label">Жанр</label>
                                <input asp-for="Genre" list="genresList" class="form-input" />
                                <datalist id="genresList">
                                    <option>Классика</option><option>Фэнтези</option><option>Детектив</option>
                                    <option>Антиутопия</option><option>Научная фантастика</option><option>Магический реализм</option>
                                    <option>Биография</option><option>Нон-фикшн</option><option>Другое</option>
                                </datalist>
                            </div>
                            <div class="form-group">
                                <label asp-for="Condition" class="form-label">Состояние</label>
                                <select asp-for="Condition" class="form-input form-select">
                                    @foreach (var c in Enum.GetValues<BookCondition>())
                                    {
                                        <option value="@c">@MappingProfile.ConditionToLabel(c)</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Year" class="form-label">Год</label>
                                <input asp-for="Year" type="number" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label asp-for="Language" class="form-label">Язык</label>
                                <input asp-for="Language" class="form-input" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mt-4">
                    <div class="card-header">
                        <h3 class="card-title">Обложка</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group" style="margin-bottom:0;">
                            <label asp-for="CoverImage" class="form-label">Файл <span class="text-muted text-xs">(jpg / png, до 5 МБ)</span></label>
                            <input asp-for="CoverImage" type="file" accept="image/*" class="form-input" />
                            @if (!string.IsNullOrEmpty(Model.ExistingCoverPath))
                            {
                                <div class="flex items-center gap-2 mt-3">
                                    <img src="@Model.ExistingCoverPath" alt="" style="height:80px;border-radius:8px;box-shadow:var(--shadow-sm);" />
                                    <span class="text-muted text-sm">Текущая обложка</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="flex gap-2 mt-6">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <svg class="icon"><use href="#i-check"/></svg>
                        @(isEdit ? "Сохранить" : "Добавить книгу")
                    </button>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-outline btn-lg">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('fetchIsbnBtn')?.addEventListener('click', async () => {
            const isbn = document.getElementById('isbnInput').value.trim();
            if (!isbn) return alert('Введите ISBN');
            const res = await fetch('/Book/FetchByIsbn?isbn=' + encodeURIComponent(isbn));
            const data = await res.json();
            if (data?.title) {
                document.querySelector('[name="Title"]').value = data.title;
                document.querySelector('[name="Author"]').value = data.author || '';
                document.querySelector('[name="Year"]').value = data.year || '';
                document.querySelector('[name="Description"]').value = data.description || '';
            } else {
                alert('Не нашли книгу по этому ISBN');
            }
        });
    </script>
}
