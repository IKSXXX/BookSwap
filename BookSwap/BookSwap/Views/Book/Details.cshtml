@model BookDetailsViewModel
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@{
    ViewData["Title"] = Model.Title;
    var currentId = UserManager.GetUserId(User);
    var isOwner = currentId != null && Model.Owners.Any(o => o.Id == currentId);
    string conditionClass = Model.ConditionLabel switch
    {
        "Отличное" or "Новое" => "badge--green",
        "Хорошее"             => "badge--blue",
        "Удовлетворительное"  => "badge--yellow",
        _                     => "badge--secondary"
    };
    var hasCover = !string.IsNullOrEmpty(Model.CoverImagePath);
}

@* ───────────────────── HERO ───────────────────── *@
<div class="bd-hero">
    @if (hasCover)
    {
        <div class="bd-hero__bg" style="background-image:url('@Model.CoverImagePath')"></div>
    }
    <div class="bd-hero__overlay"></div>

    <div class="container bd-hero__inner">
        <a asp-controller="Book" asp-action="Index" class="bd-back-link">
            <svg class="icon"><use href="#i-arrow-left"/></svg>
            Назад к каталогу
        </a>

        <div class="bd-hero__layout">
            @* Обложка *@
            <div class="bd-cover-wrap">
                @if (hasCover)
                {
                    <img src="@Model.CoverImagePath" alt="@Model.Title" class="bd-cover" />
                }
                else
                {
                    <div class="bd-cover bd-cover--placeholder">
                        <svg class="icon" style="width:3rem;height:3rem;opacity:.4"><use href="#i-book"/></svg>
                    </div>
                }
            </div>

            @* Информация *@
            <div class="bd-hero__info">
                <div class="bd-badges mb-3">
                    <span class="badge @conditionClass">@Model.ConditionLabel</span>
                    <span class="badge badge--secondary">@Model.Genre</span>
                    @if (Model.IsAvailable)
                    {
                        <span class="badge badge--green">Доступна</span>
                    }
                    else
                    {
                        <span class="badge badge--red">Недоступна</span>
                    }
                </div>

                <h1 class="bd-title">@Model.Title</h1>
                <p class="bd-author">@Model.Author</p>

                @if (Model.Year.HasValue || !string.IsNullOrEmpty(Model.Language))
                {
                    <div class="bd-attrs">
                        @if (Model.Year.HasValue)
                        {
                            <span><svg class="icon"><use href="#i-calendar"/></svg>@Model.Year</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Language))
                        {
                            <span><svg class="icon"><use href="#i-book"/></svg>@Model.Language</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="bd-desc">@Model.Description</p>
                }

                @* Действия *@
                <div class="bd-actions">
                    @if (SignInManager.IsSignedIn(User) && !isOwner && Model.IsAvailable)
                    {
                        <a asp-controller="Exchange" asp-action="Create" asp-route-bookId="@Model.Id"
                           class="btn btn-primary">
                            <svg class="icon"><use href="#i-swap"/></svg>
                            Предложить обмен
                        </a>
                    }
                    else if (!SignInManager.IsSignedIn(User) && Model.IsAvailable)
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                            <svg class="icon"><use href="#i-swap"/></svg>
                            Войти и предложить обмен
                        </a>
                    }
                    else if (!Model.IsAvailable && !isOwner)
                    {
                        <span class="bd-unavailable">
                            <svg class="icon"><use href="#i-x"/></svg>
                            Недоступна для обмена
                        </span>
                    }

                    @if (SignInManager.IsSignedIn(User) && !isOwner)
                    {
                        <form asp-controller="Favorite" asp-action="Toggle" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button type="submit" class="bd-fav-btn @(Model.IsFavorite ? "is-active" : "")">
                                <svg class="icon"><use href="#i-heart"/></svg>
                                @(Model.IsFavorite ? "В избранном" : "В избранное")
                            </button>
                        </form>
                        <form asp-controller="Favorite" asp-action="Toggle" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <input type="hidden" name="isWishlist" value="true" />
                            <button type="submit" class="bd-fav-btn @(Model.IsInWishlist ? "is-active" : "")">
                                <svg class="icon"><use href="#i-bookmark"/></svg>
                                @(Model.IsInWishlist ? "В вишлисте" : "В вишлист")
                            </button>
                        </form>
                    }

                    @if (isOwner)
                    {
                        <a asp-controller="Book" asp-action="Edit" asp-route-id="@Model.Id"
                           class="btn btn-outline bd-btn-light">
                            <svg class="icon"><use href="#i-edit"/></svg>
                            Редактировать
                        </a>
                        <form asp-controller="Book" asp-action="Delete" method="post"
                              onsubmit="return confirm('Удалить книгу?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button class="btn btn-reject">
                                <svg class="icon"><use href="#i-trash"/></svg>
                                Удалить
                            </button>
                        </form>
                    }
                </div>
            </div>

            @* Владельцы *@
            <div class="bd-owners">
                <p class="bd-owners__label">@(Model.Owners.Count > 1 ? "Владельцы" : "Владелец")</p>
                @foreach (var owner in Model.Owners)
                {
                    <a asp-controller="User" asp-action="Details" asp-route-id="@owner.Id" class="bd-owner-row">
                        <img src="@(string.IsNullOrEmpty(owner.Avatar) ? "/images/avatars/profile_icon.png" : owner.Avatar)"
                             alt="@owner.Name" class="bd-owner-avatar" />
                        <div>
                            <div class="bd-owner-name">@owner.Name</div>
                            <div class="bd-owner-rating">
                                <svg class="icon rating-star" style="width:.75rem;height:.75rem"><use href="#i-star"/></svg>
                                @owner.Rating.ToString("0.0")
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@* ───────────────────── BODY ───────────────────── *@
<div class="section--gray" style="padding:2.5rem 0;">
    <div class="container">
        <div class="tabs">
            <div class="tabs-list">
                <button type="button" class="tab-btn active" data-tab="discussions">
                    <svg class="icon"><use href="#i-chat"/></svg>
                    Обсуждения (@Model.Discussions.Count)
                </button>
                <button type="button" class="tab-btn" data-tab="similar">
                    <svg class="icon"><use href="#i-book"/></svg>
                    Похожие книги (@Model.Similar.Count)
                </button>
            </div>

            <div class="tab-content" id="tab-discussions">
                @if (SignInManager.IsSignedIn(User))
                {
                    <form asp-controller="Discussion" asp-action="Create" method="post" class="disc-create-form mb-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <input type="text" name="title" class="form-input"
                               placeholder="Новая тема обсуждения…" required maxlength="300" />
                        <button type="submit" class="btn btn-primary">
                            <svg class="icon"><use href="#i-plus"/></svg>
                            Создать
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-muted mb-4 text-sm">
                        Чтобы создать тему, <a asp-controller="Account" asp-action="Login" class="text-primary">войдите</a>.
                    </p>
                }

                @if (Model.Discussions.Count == 0)
                {
                    <div class="empty-state">
                        <svg class="icon"><use href="#i-chat"/></svg>
                        <p>Пока нет обсуждений — будьте первым!</p>
                    </div>
                }
                else
                {
                    <div class="stack">
                        @foreach (var d in Model.Discussions)
                        {
                            <a asp-controller="Discussion" asp-action="Details" asp-route-id="@d.Id"
                               class="exchange-row">
                                <div class="exchange-row__main">
                                    <div class="exchange-row__body">
                                        <div class="exchange-row__name-link">@d.Title</div>
                                        <div class="exchange-row__sub">
                                            @d.AuthorName · @d.MessagesCount сообщений ·
                                            @d.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                                        </div>
                                    </div>
                                </div>
                                <svg class="icon text-muted"><use href="#i-arrow-right"/></svg>
                            </a>
                        }
                    </div>
                }
            </div>

            <div class="tab-content" id="tab-similar" hidden>
                @if (Model.Similar.Count == 0)
                {
                    <div class="empty-state">
                        <svg class="icon"><use href="#i-book"/></svg>
                        <p>Похожих книг пока нет.</p>
                    </div>
                }
                else
                {
                    <div class="book-grid">
                        @foreach (var s in Model.Similar)
                        {
                            <partial name="_BookCard" model="s" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
