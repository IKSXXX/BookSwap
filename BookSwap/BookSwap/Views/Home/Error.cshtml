@{ ViewData["Title"] = "Ошибка"; }

<div class="section--gray" style="padding:4rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <div class="empty-state card" style="max-width:540px;margin:0 auto;">
            <svg class="icon" style="width:64px;height:64px;color:var(--red-600);"><use href="#i-alert"/></svg>
            <h2 class="mt-3 mb-2">Что-то пошло не так</h2>
            <p class="text-muted mb-4">При обработке запроса произошла ошибка. Попробуйте вернуться на главную.</p>
            <a href="/" class="btn btn-primary">
                <svg class="icon"><use href="#i-home"/></svg>
                На главную
            </a>
        </div>
    </div>
</div>
