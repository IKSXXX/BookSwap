@model HomeViewModel
@{
    ViewData["Title"] = "Главная";
}

<section class="hero">
    <div class="container">
        <h1>Обменивайтесь книгами</h1>
        <p>Найдите книгу для чтения или поделитесь своей коллекцией с другими читателями</p>
        <div class="hero__ctas">
            <a asp-controller="Book" asp-action="Index" class="btn btn-primary btn-lg">Найти книги</a>
            <a asp-controller="Book" asp-action="Create" class="btn btn-outline btn-lg">Добавить свои книги</a>
        </div>
    </div>
</section>

<section class="section--gray">
    <div class="container">
        <h2 class="text-center mb-4">Как это работает</h2>
        <div class="steps-grid">
            <div class="step">
                <div class="step__icon step__icon--blue">1</div>
                <h3>Найдите книгу</h3>
                <p>Просматривайте каталог книг других читателей</p>
            </div>
            <div class="step">
                <div class="step__icon step__icon--green">2</div>
                <h3>Предложите обмен</h3>
                <p>Выберите книгу из своей коллекции для обмена</p>
            </div>
            <div class="step">
                <div class="step__icon step__icon--yellow">3</div>
                <h3>Получите книгу</h3>
                <p>Договоритесь о встрече и получите книгу</p>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="container">
        <h2 class="mb-4">Недавно добавленные</h2>
        @if (Model.RecentBooks.Count > 0)
        {
            <div class="book-grid">
                @foreach (var book in Model.RecentBooks)
                {
                    <partial name="_BookCard" model="book" />
                }
            </div>
        }
        else
        {
            <p class="text-muted">Пока нет книг.</p>
        }
    </div>
</section>

@if (Model.BookOfTheDay != null || Model.QuizQuestion != null)
{
    <section class="section--gray">
        <div class="container">
            <h2 class="text-center mb-4">Сегодня на полке</h2>
            <div class="home-pair">
                @if (Model.BookOfTheDay != null)
                {
                    <div class="card">
                        <div class="card-body">
                            <div class="feature-label mb-3">
                                <svg class="icon" style="color:var(--yellow-400);"><use href="#i-star"/></svg>
                                Книга дня
                            </div>
                            <a asp-controller="Book" asp-action="Details" asp-route-id="@Model.BookOfTheDay.Id" class="feature-cover">
                                @if (!string.IsNullOrEmpty(Model.BookOfTheDay.CoverImagePath))
                                {
                                    <img src="@Model.BookOfTheDay.CoverImagePath" alt="@Model.BookOfTheDay.Title" />
                                }
                            </a>
                            <h3 class="mt-3 mb-1">@Model.BookOfTheDay.Title</h3>
                            <p class="text-muted">@Model.BookOfTheDay.Author</p>
                        </div>
                    </div>
                }

                @if (Model.QuizQuestion != null)
                {
                    <div class="card">
                        <div class="card-body">
                            <div class="feature-label mb-3">
                                <svg class="icon" style="color:var(--blue-500);"><use href="#i-book"/></svg>
                                Угадай книгу
                            </div>
                            <p class="quiz-quote">«@Model.QuizQuestion.Quote»</p>
                            <div class="quiz-options" id="quizOptions" data-question-id="@Model.QuizQuestion.Id">
                                @foreach (var opt in Model.QuizQuestion.Options)
                                {
                                    <button type="button" class="quiz-option" data-answer="@opt">@opt</button>
                                }
                            </div>
                            <div id="quizResult" class="quiz-result" hidden></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@section Scripts {
    <script>
        document.querySelectorAll('.quiz-option').forEach(btn => {
            btn.addEventListener('click', async () => {
                const container = document.getElementById('quizOptions');
                const questionId = container.dataset.questionId;
                const answer = btn.dataset.answer;
                const result = document.getElementById('quizResult');
                container.querySelectorAll('.quiz-option').forEach(b => b.disabled = true);
                const res = await fetch('/quiz/answer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `questionId=${questionId}&answer=${encodeURIComponent(answer)}`
                });
                const data = await res.json();
                if (data.isCorrect) {
                    btn.classList.add('quiz-option--correct');
                    result.textContent = 'Правильно!';
                } else {
                    btn.classList.add('quiz-option--wrong');
                    result.textContent = `Неверно. Ответ: ${data.correctAnswer}`;
                }
                result.hidden = false;
            });
        });
    </script>
}
