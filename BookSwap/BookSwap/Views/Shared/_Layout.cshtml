@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@{
    var isSignedIn = SignInManager.IsSignedIn(User);
    var currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var isAdmin = currentUser != null && await UserManager.IsInRoleAsync(currentUser, "Admin");
    var currentController = (string?)ViewContext.RouteData.Values["controller"] ?? "";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "BookSwap")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
        <defs>
            <symbol id="i-book" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></symbol>
            <symbol id="i-search" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></symbol>
            <symbol id="i-user" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></symbol>
            <symbol id="i-heart" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></symbol>
            <symbol id="i-star" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></symbol>
            <symbol id="i-swap" viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></symbol>
            <symbol id="i-plus" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></symbol>
            <symbol id="i-edit" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></symbol>
            <symbol id="i-x" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></symbol>
            <symbol id="i-check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></symbol>
            <symbol id="i-location" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></symbol>
            <symbol id="i-calendar" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></symbol>
            <symbol id="i-bookmark" viewBox="0 0 24 24"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></symbol>
            <symbol id="i-sparkles" viewBox="0 0 24 24"><path d="M12 2l2.4 7.2H22l-6 4.8 2.4 7.2L12 16.8l-6.4 4.4L8 14l-6-4.8h7.6z"/></symbol>
            <symbol id="i-bell" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></symbol>
            <symbol id="i-message-circle" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></symbol>
            <symbol id="i-logout" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></symbol>
            <symbol id="i-arrow-left" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></symbol>
            <symbol id="i-arrow-right" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></symbol>
            <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
            <symbol id="i-home" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></symbol>
            <symbol id="i-send" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></symbol>
        </defs>
    </svg>

    <header>
        <div class="container">
            <nav class="navbar">
                <a asp-controller="Home" asp-action="Index" class="brand">BookSwap</a>
                <div class="nav-links">
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(currentController == "Home" ? "is-active" : "")">Главная</a>
                    <a asp-controller="Book" asp-action="Index" class="nav-link @(currentController == "Book" ? "is-active" : "")">Каталог</a>
                    @if (isSignedIn && currentUser != null)
                    {
                        <a asp-controller="User" asp-action="Details" asp-route-id="@currentUser.Id" class="nav-link @(currentController == "User" ? "is-active" : "")">Профиль</a>
                        @if (isAdmin)
                        {
                            <a asp-controller="Admin" asp-action="Index" class="nav-link @(currentController == "Admin" ? "is-active" : "")">Админ</a>
                        }
                    }
                </div>
                <div class="nav-cta">
                    @if (isSignedIn && currentUser != null)
                    {
                        <div class="notif-bell-wrap" style="position:relative;">
                            <button class="notif-bell" id="notifBell" title="Уведомления">
                                <svg class="icon"><use href="#i-bell"/></svg>
                                <span class="notif-bell__count" id="notifCount" style="display:none;">0</span>
                            </button>
                            <div class="notif-dropdown" id="notifDropdown">
                                <div class="notif-dropdown__head">
                                    <h4>Уведомления</h4>
                                    <button class="btn btn-ghost btn-sm" id="notifClearAll" style="font-size:.75rem;padding:.25rem .5rem;">Очистить</button>
                                </div>
                                <div class="notif-dropdown__list" id="notifList">
                                    <div class="notif-empty">Нет уведомлений</div>
                                </div>
                            </div>
                        </div>
                        <a asp-controller="User" asp-action="Details" asp-route-id="@currentUser.Id" class="btn btn-primary btn-sm">
                            <svg class="icon"><use href="#i-user"/></svg>
                            Профиль
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-ghost btn-sm" title="Выйти">
                                <svg class="icon"><use href="#i-logout"/></svg>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="MockLogin" class="btn btn-primary btn-sm">Войти</a>
                    }
                </div>
            </nav>
        </div>
    </header>

    <div class="page-wrap">
        <main class="fade-in">
            @if (TempData["Success"] is string ok)
            {
                <div class="container" style="padding-top:1rem">
                    <div class="alert alert--success">
                        <svg class="icon"><use href="#i-check"/></svg>
                        <span>@ok</span>
                    </div>
                </div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="container" style="padding-top:1rem">
                    <div class="alert alert--danger">
                        <svg class="icon"><use href="#i-x"/></svg>
                        <span>@err</span>
                    </div>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <p>© @DateTime.Now.Year BookSwap</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        document.getElementById('navToggle')?.addEventListener('click', () => {
            document.getElementById('navLinks')?.classList.toggle('is-open');
        });
        document.addEventListener('click', e => {
            const btn = e.target.closest('.tab-btn');
            if (!btn) return;
            const tab = btn.dataset.tab;
            const container = btn.closest('.tabs');
            if (!container || !tab) return;
            container.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b === btn));
            container.querySelectorAll('.tab-content').forEach(c => c.hidden = (c.id !== 'tab-' + tab));
        });
    </script>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        const ToastManager = {
            container: null,
            init() {
                this.container = document.getElementById('toastContainer');
                document.querySelectorAll('.alert--success').forEach(el => {
                    this.show(el.textContent.trim(), 'success');
                    el.closest('.container')?.remove();
                });
                document.querySelectorAll('.alert--danger').forEach(el => {
                    this.show(el.textContent.trim(), 'error');
                    el.closest('.container')?.remove();
                });
            },
            show(message, type = 'info', duration = 7000) {
                const icons = { success: '#i-check', error: '#i-x', info: '#i-bookmark', warning: '#i-star' };
                const titles = { success: 'Успешно', error: 'Ошибка', info: 'Информация', warning: 'Внимание' };
                const toast = document.createElement('div');
                toast.className = `toast toast--${type}`;
                toast.innerHTML = `
                    <div class="toast__icon"><svg class="icon"><use href="${icons[type] || icons.info}"/></svg></div>
                    <div class="toast__body">
                        <div class="toast__title">${titles[type] || titles.info}</div>
                        <div class="toast__text">${message}</div>
                    </div>
                    <button class="toast__close" title="Закрыть"><svg class="icon"><use href="#i-x"/></svg></button>
                    <div class="toast__progress"><div class="toast__progress-bar" style="width:100%"></div></div>
                `;
                this.container.appendChild(toast);
                const bar = toast.querySelector('.toast__progress-bar');
                if (bar) {
                    bar.style.width = '100%';
                    requestAnimationFrame(() => {
                        bar.style.transition = `width ${duration}ms linear`;
                        bar.style.width = '0%';
                    });
                }
                toast.querySelector('.toast__close').addEventListener('click', () => this.dismiss(toast));
                const timer = setTimeout(() => this.dismiss(toast), duration);
                toast._timer = timer;
                return toast;
            },
            dismiss(toast) {
                if (toast._timer) clearTimeout(toast._timer);
                toast.classList.add('toast--exit');
                setTimeout(() => toast.remove(), 300);
            }
        };

        const NotifManager = {
            bell: null, dropdown: null, countEl: null, listEl: null, notifications: [],
            init() {
                this.bell = document.getElementById('notifBell');
                this.dropdown = document.getElementById('notifDropdown');
                this.countEl = document.getElementById('notifCount');
                this.listEl = document.getElementById('notifList');
                if (!this.bell) return;
                this.bell.addEventListener('click', e => {
                    e.stopPropagation();
                    this.dropdown.classList.toggle('is-open');
                });
                document.addEventListener('click', e => {
                    if (!this.dropdown?.contains(e.target) && !this.bell?.contains(e.target))
                        this.dropdown?.classList.remove('is-open');
                });
                document.getElementById('notifClearAll')?.addEventListener('click', () => {
                    this.notifications = [];
                    this.render();
                });
                this.load();
            },
            add(text, type = 'exchange') {
                this.notifications.unshift({ id: Date.now(), text, type, time: new Date().toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }), unread: true });
                if (this.notifications.length > 20) this.notifications.pop();
                this.save();
                this.render();
                ToastManager.show(text, 'info');
            },
            render() {
                if (!this.listEl) return;
                const unread = this.notifications.filter(n => n.unread).length;
                this.countEl.style.display = unread > 0 ? 'grid' : 'none';
                this.countEl.textContent = unread > 9 ? '9+' : unread;
                if (this.notifications.length === 0) {
                    this.listEl.innerHTML = '<div class="notif-empty">Нет уведомлений</div>';
                    return;
                }
                this.listEl.innerHTML = this.notifications.map(n => `
                    <div class="notif-item ${n.unread ? 'unread' : ''}" data-id="${n.id}">
                        <div class="notif-item__icon notif-item__icon--${n.type}">
                            <svg class="icon"><use href="#${n.type === 'exchange' ? 'i-swap' : n.type === 'review' ? 'i-star' : 'i-message-circle'}"/></svg>
                        </div>
                        <div class="notif-item__body">
                            <div class="notif-item__text">${n.text}</div>
                            <div class="notif-item__time">${n.time}</div>
                        </div>
                    </div>
                `).join('');
                this.listEl.querySelectorAll('.notif-item').forEach(el => {
                    el.addEventListener('click', () => {
                        const id = parseInt(el.dataset.id);
                        const notif = this.notifications.find(n => n.id === id);
                        if (notif) notif.unread = false;
                        this.save();
                        this.render();
                    });
                });
            },
            save() { try { localStorage.setItem('bookswap_notifications', JSON.stringify(this.notifications)); } catch {} },
            load() { try { const d = localStorage.getItem('bookswap_notifications'); if (d) this.notifications = JSON.parse(d); } catch {} this.render(); },
            connectSignalR() {
                if (typeof signalR === 'undefined') return;
                const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/chat').withAutomaticReconnect().build();
                conn.on('ReceiveNotification', n => this.add(n.text, n.type || 'exchange'));
                conn.start().catch(() => {});
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
            ToastManager.init();
            NotifManager.init();
            NotifManager.connectSignalR();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
