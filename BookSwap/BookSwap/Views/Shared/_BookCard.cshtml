@*
    Карточка книги — соответствует Figma BookCard: обложка 3:4, бейдж состояния справа сверху,
    заголовок / автор / жанр в теле и метаинформация внизу.
*@
@model BookCardViewModel
@{
    string conditionClass = Model.ConditionLabel switch
    {
        "Отличное" => "badge--green",
        "Новое" => "badge--green",
        "Хорошее" => "badge--blue",
        "Удовлетворительное" => "badge--yellow",
        _ => "badge--secondary"
    };
}

<a class="book-card" asp-controller="Book" asp-action="Details" asp-route-id="@Model.Id">
    <div class="book-card__media">
        @if (!string.IsNullOrWhiteSpace(Model.CoverImagePath))
        {
            <img src="@Model.CoverImagePath" alt="@Model.Title" loading="lazy" />
        }
        else
        {
            <div class="book-card__placeholder">
                <svg class="icon"><use href="#i-book" /></svg>
            </div>
        }
        @if (!Model.IsAvailable)
        {
            <span class="badge badge--red book-card__badge">Недоступна</span>
        }
        else if (!string.IsNullOrWhiteSpace(Model.ConditionLabel))
        {
            <span class="badge @conditionClass book-card__badge">@Model.ConditionLabel</span>
        }
    </div>
    <div class="book-card__body">
        <h3 class="book-card__title">@Model.Title</h3>
        <p class="book-card__author">@Model.Author</p>
        <span class="badge badge--secondary">@Model.Genre</span>
        @if (!string.IsNullOrWhiteSpace(Model.Owner.Name))
        {
            <span class="book-card__owner-name">@Model.Owner.Name</span>
        }
    </div>
</a>
